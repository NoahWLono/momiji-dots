{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

    // Momiji Arch logo:
    // 1 = harvest gold
    // 2 = autumn auburn
    // 3 = agricultural green
    "logo": {
        "type": "file",
        "source": "~/momiji-dots/rice/fastfetch/arch-maple.txt",
        "padding": {
            "right": 2
        },
        "color": {
            "1": "#D4A017",
            "2": "#9A3F24",
            "3": "#4F7A3A"
        }
    }
}
